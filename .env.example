# Copy to .env (gitignored) and fill in. The moodle-mcp server and the
# moodle-ingest script both read from process env; .env is loaded by
# python-dotenv (auto-loaded when present) or by your shell.

# ─── Moodle (required for both server and ingest) ───────────────────────
MOODLE_URL=https://moodle.your-tenant.example
MOODLE_TOKEN=your_moodle_ws_token_here

# ─── Qdrant (required for moodle-ingest only) ───────────────────────────
# When ingesting from your laptop, open an SSH tunnel first:
#   ssh -L 6333:127.0.0.1:6333 -N -f root@<vps>
# then point QDRANT_URL at localhost.
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=paste_from_vps_/etc/qdrant/qdrant.env

# ─── OpenAI (required for moodle-ingest only) ───────────────────────────
# Get from https://platform.openai.com/api-keys signed in as admin@didaflow.com
# Used for text-embedding-3-small (1536 dims).
OPENAI_API_KEY=sk-proj-...
# Optional: bind usage to a specific OpenAI project for clean billing.
# OPENAI_PROJECT_ID=proj_...
